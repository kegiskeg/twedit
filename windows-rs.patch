+/// Set the window (title bar + taskbar) icon from a `.ico` file path.
+/// Queued if the root window isn't attached yet.
+pub fn set_window_icon(path: impl Into<String>) {
+    let path = path.into();
+    let applied = ROOT_WINDOW.with(|wcell| -> Option<()> {
+        let window = wcell.borrow();
+        apply_window_icon(window.as_ref()?, &path)
+    });
+    if applied.is_none() {
+        PENDING_ICON.with(|p| *p.borrow_mut() = Some(path));
+    }
+}
