+
+/// Parse `xaml` (which must describe a `ResourceDictionary`) and merge it
+/// into `Application.Resources`. Appended after the WinUI control resources,
+/// so its keys take precedence in resource lookup — this is the hook for
+/// lightweight-styling theme overrides.
+pub fn install_theme_resources(app: &Application, xaml: &str) -> Result<()> {
+    let loaded = XamlReader::Load(xaml)?;
+    let dict: ResourceDictionary = loaded.cast()?;
+    let resources = app.Resources()?;
+    let merged = resources.MergedDictionaries()?;
+    merged.Append(&dict)?;
+    Ok(())
+}
