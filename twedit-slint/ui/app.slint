import { ListView } from "std-widgets.slint";
import { Theme, Btn, WinBtn, NavTab, TypeBadge, ValueField } from "theme.slint";

export struct FactionRow {
    name: string,
    key: string,
    status: string,
    treasury: string,
    swatch: color,
    major: bool,
    destroyed: bool,
}

export struct TreeRow {
    node-id: int,
    label: string,
    depth: int,
    has-children: bool,
    expanded: bool,
    selected: bool,
}

export struct ValueRow {
    value-id: int,
    value: string,
    original: string,
    type-name: string,
    label: string,
    edited: bool,
    editable: bool,
}

export component AppWindow inherits Window {
    // Data in.
    in property <[FactionRow]> factions;
    in property <[TreeRow]> tree-rows;
    in property <[ValueRow]> values;
    in property <string> status-text;
    in property <string> doc-stats;
    in property <string> node-path;
    in property <string> node-doc;
    in property <string> save-label: "Save";
    in property <int> pending-count: 0;
    in property <bool> has-doc: false;
    // State shared with Rust.
    in-out property <bool> edit-mode: false;
    in-out property <int> view: 0;
    // Events out.
    callback start-drag();
    callback close-clicked();
    callback open();
    callback save();
    callback select-node(int);
    callback toggle-expand(int);
    callback edit-value(int, string);
    callback toggle-edit(bool);

    title: "Twedit — Total War Save Editor";
    background: Theme.base;
    default-font-family: Theme.font;
    default-font-size: 13px;
    preferred-width: 1280px;
    preferred-height: 840px;
    min-width: 900px;
    min-height: 560px;
    no-frame: true;
    resize-border-width: 6px;

    VerticalLayout {
        // ============================ TITLE BAR ============================
        Rectangle {
            height: 44px;
            background: @linear-gradient(180deg, #201c14 0%, #17140f 100%);
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
            TouchArea {
                pointer-event(e) => {
                    if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                        root.start-drag();
                    }
                }
                double-clicked => {
                    root.maximized = !root.maximized;
                }
            }
            HorizontalLayout {
                padding-left: 16px;
                spacing: 9px;
                VerticalLayout {
                    alignment: center;
                    HorizontalLayout {
                        spacing: 9px;
                        Text {
                            text: "Twedit";
                            color: Theme.accent;
                            font-family: Theme.serif;
                            font-size: 19px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "TOTAL WAR SAVE EDITOR";
                            color: Theme.faint;
                            font-size: 9px;
                            letter-spacing: 1.5px;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                WinBtn {
                    glyph: "\u{2013}";
                    clicked => {
                        root.minimized = true;
                    }
                }
                WinBtn {
                    glyph: "\u{25A1}";
                    clicked => {
                        root.maximized = !root.maximized;
                    }
                }
                WinBtn {
                    glyph: "\u{2715}";
                    danger: true;
                    clicked => {
                        root.close-clicked();
                    }
                }
            }
        }

        // ============================ TOOLBAR =============================
        Rectangle {
            height: 52px;
            background: @linear-gradient(180deg, #1a1711 0%, #151209 100%);
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 8px;
                alignment: start;

                VerticalLayout {
                    alignment: center;
                    Btn {
                        label: "Open";
                        clicked => {
                            root.open();
                        }
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Btn {
                        label: root.save-label;
                        primary: root.pending-count > 0;
                        enabled: root.has-doc;
                        clicked => {
                            root.save();
                        }
                    }
                }

                // View / Edit segmented toggle.
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 132px;
                        height: 30px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: Theme.well;
                        clip: true;
                        HorizontalLayout {
                            seg-view := Rectangle {
                                background: !root.edit-mode ? Theme.accent : transparent;
                                Text {
                                    text: "View";
                                    color: !root.edit-mode ? Theme.base : Theme.dim;
                                    font-weight: 700;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea {
                                    clicked => {
                                        root.toggle-edit(false);
                                    }
                                }
                            }
                            seg-edit := Rectangle {
                                background: root.edit-mode ? Theme.accent : transparent;
                                Text {
                                    text: "Edit";
                                    color: root.edit-mode ? Theme.base : Theme.dim;
                                    font-weight: 700;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea {
                                    clicked => {
                                        root.toggle-edit(true);
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // View switcher.
                NavTab {
                    label: "Explorer";
                    active: root.view == 0;
                    clicked => {
                        root.view = 0;
                    }
                }
                NavTab {
                    label: "Factions";
                    active: root.view == 1;
                    clicked => {
                        root.view = 1;
                    }
                }
            }
        }

        // ============================== BODY ==============================
        Rectangle {
            background: Theme.base;

            // ---- Explorer: tree | value grid ----
            if root.view == 0: HorizontalLayout {
                padding: 12px;
                spacing: 12px;

                // Tree card
                Rectangle {
                    width: 340px;
                    background: Theme.panel;
                    border-radius: Theme.radius;
                    border-width: 1px;
                    border-color: Theme.border;
                    drop-shadow-blur: 14px;
                    drop-shadow-color: Theme.shadow;
                    drop-shadow-offset-y: 3px;
                    clip: true;
                    ListView {
                        for row in root.tree-rows: Rectangle {
                            height: 27px;
                            background: row.selected ? Theme.raised : (touch.has-hover ? Theme.header : transparent);
                            animate background { duration: 80ms; }
                            // selection accent bar
                            Rectangle {
                                x: 0;
                                width: 3px;
                                background: row.selected ? Theme.accent : transparent;
                            }
                            touch := TouchArea {
                                clicked => {
                                    root.select-node(row.node-id);
                                }
                            }
                            HorizontalLayout {
                                padding-left: 6px + row.depth * 15px;
                                padding-right: 8px;
                                spacing: 2px;
                                // chevron / expand toggle
                                Rectangle {
                                    width: 18px;
                                    chev := Text {
                                        text: row.has-children ? (row.expanded ? "\u{25BC}" : "\u{25BA}") : "";
                                        color: chev-touch.has-hover ? Theme.accent-bright : Theme.dim;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    chev-touch := TouchArea {
                                        clicked => {
                                            root.toggle-expand(row.node-id);
                                        }
                                    }
                                }
                                Text {
                                    text: row.label;
                                    color: row.selected ? Theme.accent-bright : Theme.text;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                // Value grid card
                Rectangle {
                    background: Theme.panel;
                    border-radius: Theme.radius;
                    border-width: 1px;
                    border-color: Theme.border;
                    drop-shadow-blur: 14px;
                    drop-shadow-color: Theme.shadow;
                    drop-shadow-offset-y: 3px;
                    clip: true;
                    VerticalLayout {
                        // node header
                        Rectangle {
                            height: root.node-path == "" ? 0px : 52px;
                            background: Theme.header;
                            Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                background: Theme.border;
                            }
                            VerticalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 8px;
                                spacing: 2px;
                                Text {
                                    text: root.node-path;
                                    color: Theme.accent-bright;
                                    font-size: 13px;
                                    font-weight: 700;
                                    overflow: elide;
                                }
                                Text {
                                    text: root.node-doc;
                                    color: Theme.dim;
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }
                        }
                        // column header
                        Rectangle {
                            height: 30px;
                            background: Theme.panel-alt;
                            Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                background: Theme.border;
                            }
                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 12px;
                                Text { width: 240px; text: "VALUE"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                                Text { width: 180px; text: "ORIGINAL"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                                Text { width: 110px; text: "TYPE"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                                Text { text: "FIELD"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                            }
                        }
                        // rows
                        if root.values.length == 0: Rectangle {
                            Text {
                                text: root.has-doc ? "Select a node to view its values." : "Open a save file to begin.";
                                color: Theme.faint;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        if root.values.length > 0: ListView {
                            for v[i] in root.values: Rectangle {
                                height: 40px;
                                background: row-touch.has-hover ? Theme.header : (v.edited ? #241d0e : (mod(i, 2) == 1 ? Theme.panel-alt : Theme.panel));
                                animate background { duration: 70ms; }
                                Rectangle {
                                    y: parent.height - 1px;
                                    height: 1px;
                                    background: Theme.border-soft;
                                }
                                row-touch := TouchArea { }
                                HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 12px;
                                    // value cell
                                    VerticalLayout {
                                        width: 240px;
                                        alignment: center;
                                        if root.edit-mode && v.editable: ValueField {
                                            text: v.value;
                                            edited: v.edited;
                                            edited-text(t) => {
                                                root.edit-value(v.value-id, t);
                                            }
                                        }
                                        if !(root.edit-mode && v.editable): Text {
                                            text: v.value;
                                            color: v.edited ? Theme.accent-bright : Theme.text;
                                            font-family: Theme.mono;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }
                                    Text {
                                        width: 180px;
                                        text: v.original;
                                        color: Theme.dim;
                                        font-family: Theme.mono;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    VerticalLayout {
                                        width: 110px;
                                        alignment: center;
                                        HorizontalLayout {
                                            alignment: start;
                                            TypeBadge { label: v.type-name; }
                                        }
                                    }
                                    Text {
                                        text: v.label;
                                        color: Theme.dim;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ---- Factions table ----
            if root.view == 1: HorizontalLayout {
                padding: 12px;
                Rectangle {
                    background: Theme.panel;
                    border-radius: Theme.radius;
                    border-width: 1px;
                    border-color: Theme.border;
                    drop-shadow-blur: 14px;
                    drop-shadow-color: Theme.shadow;
                    drop-shadow-offset-y: 3px;
                    clip: true;
                    VerticalLayout {
                        Rectangle {
                            height: 32px;
                            background: Theme.panel-alt;
                            Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                background: Theme.border;
                            }
                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 12px;
                                Text { width: 22px; text: ""; }
                                Text { width: 240px; text: "FACTION"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                                Text { width: 170px; text: "KEY"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                                Text { width: 110px; text: "STATUS"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                                Text { text: "TREASURY"; color: Theme.faint; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                            }
                        }
                        ListView {
                            for f[i] in root.factions: Rectangle {
                                height: 36px;
                                background: ftouch.has-hover ? Theme.header : (mod(i, 2) == 1 ? Theme.panel-alt : Theme.panel);
                                animate background { duration: 70ms; }
                                Rectangle {
                                    y: parent.height - 1px;
                                    height: 1px;
                                    background: Theme.border-soft;
                                }
                                ftouch := TouchArea { }
                                HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 12px;
                                    VerticalLayout {
                                        width: 22px;
                                        alignment: center;
                                        Rectangle {
                                            width: 15px;
                                            height: 15px;
                                            background: f.swatch;
                                            border-color: Theme.border;
                                            border-width: 1px;
                                            border-radius: 3px;
                                        }
                                    }
                                    Text {
                                        width: 240px;
                                        text: f.name;
                                        color: f.destroyed ? Theme.dim : Theme.text;
                                        font-size: 13px;
                                        font-weight: f.major ? 600 : 400;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        width: 170px;
                                        text: f.key;
                                        color: Theme.dim;
                                        font-family: Theme.mono;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        width: 110px;
                                        text: f.status;
                                        color: f.destroyed ? Theme.crimson : Theme.dim;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: f.treasury;
                                        color: Theme.accent-bright;
                                        font-family: Theme.mono;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ============================ STATUS BAR ==========================
        Rectangle {
            height: 27px;
            background: @linear-gradient(180deg, #201c14 0%, #17140f 100%);
            Rectangle {
                y: 0;
                height: 1px;
                background: Theme.border;
            }
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;
                Rectangle {
                    width: 3px;
                    y: (parent.height - 14px) / 2;
                    height: 14px;
                    background: Theme.accent;
                }
                Text {
                    text: root.status-text;
                    color: Theme.dim;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: root.edit-mode ? "EDIT MODE" : "";
                    color: Theme.accent;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Text {
                    text: root.doc-stats;
                    color: Theme.faint;
                    font-family: Theme.mono;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }
        }
    }
}
